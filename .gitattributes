# Unity YAML 文件使用 LF（避免 merge 冲突）
*.cs        text eol=lf
*.shader    text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.glsl      text eol=lf
*.compute   text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.asmdef    text eol=lf

# Unity 序列化文件
*.unity     text eol=lf merge=unityyamlmerge
*.prefab    text eol=lf merge=unityyamlmerge
*.asset     text eol=lf merge=unityyamlmerge
*.meta      text eol=lf merge=unityyamlmerge
*.mat       text eol=lf merge=unityyamlmerge
*.anim      text eol=lf merge=unityyamlmerge
*.controller text eol=lf merge=unityyamlmerge
*.overrideController text eol=lf merge=unityyamlmerge
*.physicsMaterial2D text eol=lf merge=unityyamlmerge
*.playable  text eol=lf merge=unityyamlmerge

# 二进制文件
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.psd       binary
*.tga       binary
*.tif       binary
*.tiff      binary
*.bmp       binary
*.exr       binary
*.hdr       binary
*.mp3       binary
*.wav       binary
*.ogg       binary
*.mp4       binary
*.mov       binary
*.avi       binary
*.fbx       binary
*.obj       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.exe       binary
